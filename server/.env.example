# 服务端口
PORT=9000
WS_PORT=10001

# JWT 配置（必须设置，否则服务无法启动）
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# 班管ID（逗号分隔，格式 YYCC00，末两位为00，中间两位为班级号）
# 例如 250100 表示25届01班班管。支持多个班级：250100,250200
# 班管不预创建账号，真实用户通过预注册名单注册后自动获得管理员权限
# 请确保预注册名单 (config/pre-records.json) 中包含对应 user_id 的用户
ADMIN_USER_IDS=250100

# 开发者账号密码（可选，设置后创建 ID=999999 的开发者账号用于测试）
# DEV_PASSWORD=dev123456

# 和风天气 API 配置
QWEATHER_KEY=your-qweather-api-key
QWEATHER_LOCATION=116.41,39.92
QWEATHER_API_HOST=devapi.qweather.com
QWEATHER_KID=
QWEATHER_SUB=
QWEATHER_PRIVATE_KEY=

# AI 聊天配置
AI_API_KEY=your-ai-api-key
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-3.5-turbo
# GPT 可用子模型列表（逗号分隔，用户可在前端切换）
AI_AVAILABLE_MODELS=gpt-4o-mini-2024-07-18,gpt-4o-mini

# DeepSeek AI 配置
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Tavily 搜索 API（AI 联网搜索功能）
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com/search

# 资源目录和数据库路径
RESOURCES_DIR=../Resources
DB_PATH=./database/classnet.db

# 中继服务器配置（多实例部署时使用）
RELAY_SERVERS=
RELAY_SECRET=
RELAY_SERVER_ID=class-a

# CORS 跨域配置
CORS_ORIGINS=

# Syncthing 文件同步配置
SYNCTHING_HOST=localhost
SYNCTHING_PORT=8384
SYNCTHING_API_KEY=

# Tailscale VPN 配置
TAILSCALE_ENABLED=false
TAILSCALE_RELAY_IP=
